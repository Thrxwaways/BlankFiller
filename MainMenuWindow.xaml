<Window x:Class="BlankFiller.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CACTUS"
        WindowState="Maximized"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="CactusGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF26A69A" Offset="0"/>
            <GradientStop Color="#FF7E57C2" Offset="0.5"/>
            <GradientStop Color="#FF26C6DA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SwitchUserBorder" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF8B5A6A" Offset="0"/>
            <GradientStop Color="#FFB85A7A" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                CornerRadius="6" x:Name="border">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"/>
                                <TextBlock x:Name="Arrow" Grid.Column="1" Text="▼" FontSize="8"
                                           Foreground="{DynamicResource StatusBarText}" VerticalAlignment="Center"
                                           Margin="6,0,0,0" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="Arrow" Property="Foreground" Value="#FF26A69A"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="HasChildren">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubMenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarSubText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="32,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                CornerRadius="4" x:Name="border">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DevSubMenuButton" TargetType="Button" BasedOn="{StaticResource SubMenuButton}">
            <Setter Property="Foreground" Value="{DynamicResource DevColor}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}" Padding="16,10" BorderBrush="{DynamicResource HeaderBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="C A C T U S" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource CactusGradient}" VerticalAlignment="Center"/>
                    <TextBlock Text="beta 0.1" FontSize="10" Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center" Margin="8,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="{DynamicResource InputBackground}" CornerRadius="8" Padding="12,6" Margin="0,0,10,0"
                            BorderBrush="#FF26A69A" BorderThickness="0.5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Инспектор" FontSize="10" Foreground="#FF26A69A"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="InspectorNameText" FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource InputBackground}" CornerRadius="8" Padding="12,6" Margin="0,0,14,0"
                            BorderBrush="{DynamicResource AccentPurple}" BorderThickness="0.5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Фельдшер" FontSize="10" Foreground="{DynamicResource AccentPurple}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="MedicNameText" FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Сменить пользователя"
                            Background="{DynamicResource DeleteButtonBackground}" Foreground="{DynamicResource RegistryAccent}"
                            BorderBrush="{StaticResource SwitchUserBorder}" BorderThickness="1"
                            Padding="14,6" Cursor="Hand" FontSize="11" FontWeight="SemiBold"
                            Click="SwitchUserButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}" x:Name="border">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DeleteButtonHover}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FFC86A8A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковая панель -->
            <Border x:Name="Sidebar" Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                    Width="240" BorderBrush="{DynamicResource SidebarBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="10,8" BorderBrush="{DynamicResource SidebarBorder}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock x:Name="SidebarLabel" Text="Свернуть боковую панель"
                                       Foreground="{DynamicResource StatusBarText}" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Button x:Name="ToggleSidebarButton" Content="◀"
                                    HorizontalAlignment="Right"
                                    Background="Transparent" Foreground="{DynamicResource StatusBarText}"
                                    BorderThickness="0" FontSize="11" Cursor="Hand"
                                    Padding="8,4" Click="ToggleSidebarButton_Click">
                                <Button.ToolTip>
                                    <ToolTip Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource SidebarText}"
                                             BorderBrush="#FF26A69A" BorderThickness="1">
                                        <TextBlock Text="Развернуть боковую панель" FontSize="12"/>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8,0,16">
                            <Button Content="🏠  На главную" Style="{StaticResource MenuButton}" Click="GoHomeButton_Click"/>

                            <Button Content="📋  Бланки" Style="{StaticResource MenuButton}" Tag="HasChildren" Click="ToggleBlanksSubmenu"/>
                            <StackPanel x:Name="BlanksSubmenu" Visibility="Collapsed">
                                <Button Content="Акт помещения" Style="{StaticResource SubMenuButton}" Click="OpenActPage_Click"/>
                                <Button Content="Уведомление и анкета" Style="{StaticResource SubMenuButton}" Click="OpenNotificationPage_Click"/>
                                <Button Content="Счёт" Style="{StaticResource SubMenuButton}" Click="OpenInvoicePage_Click"/>
                                <Button Content="Перенос данных в таблицы" Style="{StaticResource SubMenuButton}" Click="OpenDataTransferPage_Click"/>
                                <Button Content="Постановление" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                                <Button Content="Протокол" Style="{StaticResource MenuButton}" Tag="HasChildren" Click="ToggleProtocolSubmenu" Padding="26,9" FontSize="13"/>
                                <StackPanel x:Name="ProtocolSubmenu" Visibility="Collapsed">
                                    <Button Content="ч. 1 ст. 19.3" Style="{StaticResource DevSubMenuButton}" Padding="44,8" Click="InDevelopment_Click"/>
                                    <Button Content="ч. 2 ст. 19.3" Style="{StaticResource DevSubMenuButton}" Padding="44,8" Click="InDevelopment_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Content="📄  Документы" Style="{StaticResource MenuButton}" Tag="HasChildren" Click="ToggleDocsSubmenu"/>
                            <StackPanel x:Name="DocsSubmenu" Visibility="Collapsed">
                                <Button Content="Таблица доставленных" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                                <Button Content="Реестр" Style="{StaticResource SubMenuButton}" Click="OpenRegistryPage_Click"/>
                                <Button Content="Таблица должников" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                                <Button Content="Таблица по неработающим" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                                <Button Content="Таблица УОДС ГУВД" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                            </StackPanel>

                            <Button Content="🗄  База данных" Style="{StaticResource MenuButton}" Tag="HasChildren" Click="ToggleDatabaseSubmenu"/>
                            <StackPanel x:Name="DatabaseSubmenu" Visibility="Collapsed">
                                <Button Content="Новости" Style="{StaticResource SubMenuButton}" Click="OpenNewsPage_Click"/>
                                <Button Content="Вопрос-ответ [F.A.Q.]" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                                <Button Content="База помещённых" Style="{StaticResource DevSubMenuButton}" Click="InDevelopment_Click"/>
                            </StackPanel>

                            <Button Content="🔍  Сканирование" Style="{StaticResource MenuButton}" Click="InDevelopment_Click"/>
                            <Button Content="⚙  Настройки" Style="{StaticResource MenuButton}" Click="OpenSettingsPage_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Рабочая область -->
            <Border Grid.Column="1" Background="{DynamicResource AppBackground}">
                <Grid>
                    <Grid x:Name="HomeScreen">
                        <Grid VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="80,20,80,0">
                            <TextBlock x:Name="WelcomeText" Text="" FontSize="48" FontWeight="Light"
                                       Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0"/>

                            <StackPanel x:Name="ClockPanel" Opacity="0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="ClockTime" Text="00:00" FontSize="96" FontWeight="Thin"
                                               FontFamily="Segoe UI Light" Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ClockDate" Text="6 мая 2026" FontSize="22" FontWeight="Light"
                                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,16,0"/>
                                        <TextBlock x:Name="ClockDayOfWeek" Text="Среда" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource CactusGradient}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle x:Name="ClockSeparator" Height="1" Margin="0,16,0,0"
                                           Fill="{DynamicResource InputBorder}" HorizontalAlignment="Stretch"/>

                                <Border x:Name="LatestNewsBlock" Background="{DynamicResource PanelBackground}" CornerRadius="12"
                                        BorderBrush="{DynamicResource NewsAccent}" BorderThickness="1" Padding="20,16"
                                        HorizontalAlignment="Stretch" Margin="0,16,0,0" Cursor="Hand"
                                        MouseLeftButtonDown="LatestNewsBlock_Click" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel x:Name="LatestNewsContent" HorizontalAlignment="Left"/>
                                        <Border Grid.Column="1" Background="{DynamicResource NewsAccent}" CornerRadius="8"
                                                Padding="10,4" VerticalAlignment="Center" Margin="16,0,0,0">
                                            <TextBlock Text="Последние новости" FontSize="10" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button x:Name="GoToNewsButton" Content="Перейти к новостям →"
                                        Background="Transparent" Foreground="{DynamicResource AccentColor}"
                                        FontSize="13" Cursor="Hand" Padding="10,8"
                                        BorderThickness="0" HorizontalAlignment="Left"
                                        Margin="0,10,0,0" Visibility="Collapsed"
                                        Click="GoToNewsButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}" Cursor="Hand" TextDecorations="Underline"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <ContentControl x:Name="PageHost" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижний статус-бар -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBackground}" Padding="12,5"
                BorderBrush="{DynamicResource StatusBarBorder}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText" Text="Готов к работе" FontSize="11" Foreground="{DynamicResource StatusBarText}"/>
        </Border>

        <!-- Кастомный диалог подтверждения -->
        <Border x:Name="ConfirmOverlay" Grid.RowSpan="3" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource RegistryBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24" HorizontalAlignment="Center"
                    VerticalAlignment="Center" MinWidth="380">
                <StackPanel>
                    <TextBlock Text="Смена пользователя" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource RegistryAccent}" Margin="0,0,0,8"/>
                    <TextBlock Text="Вы уверены, что хотите выйти из учётной записи?"
                               FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Width="90" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1" Padding="10,6" Cursor="Hand" FontSize="12"
                                Click="CancelSwitch_Click" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}" x:Name="border">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Выйти" Width="90" Background="{DynamicResource DeleteButtonBackground}" Foreground="{DynamicResource RegistryAccent}"
                                BorderBrush="{DynamicResource DeleteButtonBorder}" BorderThickness="1" Padding="10,6" Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                                Click="ConfirmSwitch_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}" x:Name="border">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource DeleteButtonHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>