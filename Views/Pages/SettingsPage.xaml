<UserControl x:Class="BlankFiller.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="BlockLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" x:Name="border">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NeonPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPurple}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GreenButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource GreenButtonForeground}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GreenButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GreenButtonHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GreenButtonForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="80,30,80,30">
                <TextBlock Text="Настройки" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Тема интерфейса -->
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="12" BorderBrush="{DynamicResource NewsAccent}"
                        BorderThickness="1" Padding="20,14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Тема интерфейса" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Тёмная" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ToggleButton x:Name="ThemeToggle"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Checked="ThemeToggle_Changed" Unchecked="ThemeToggle_Changed">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="SwitchBorder" Width="48" Height="24"
                                                Background="{DynamicResource InputBorder}" CornerRadius="12"
                                                BorderBrush="{DynamicResource AccentColor}" BorderThickness="1">
                                            <Border x:Name="Thumb" Width="18" Height="18"
                                                    Background="{DynamicResource AccentColor}" CornerRadius="9"
                                                    HorizontalAlignment="Left" Margin="2,0,0,0">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="ThumbTransform"/>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" From="0" To="24" Duration="0:0:0.2"/>
                                                            <ColorAnimation Storyboard.TargetName="SwitchBorder" Storyboard.TargetProperty="Background.Color" To="#FF26A69A" Duration="0:0:0.2"/>
                                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Background.Color" To="#0A0A1A" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" From="24" To="0" Duration="0:0:0.2"/>
                                                            <ColorAnimation Storyboard.TargetName="SwitchBorder" Storyboard.TargetProperty="Background.Color" To="#2A2A4A" Duration="0:0:0.2"/>
                                                            <ColorAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Background.Color" To="#FF26A69A" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Text="Светлая" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Смена пароля -->
                <Border Background="{DynamicResource PanelBackground}" CornerRadius="12" BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="1" Padding="20,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Пароль пользователя" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentColor}" Margin="0,0,0,10"/>
                            <TextBlock x:Name="CurrentUserText" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <Button Content="Изменить" Width="100" Style="{StaticResource GreenButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="ChangePassword_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="PasswordModalOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource AccentColor}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420" MaxWidth="480">
                <StackPanel>
                    <TextBlock Text="Смена пароля пользователя" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Старый пароль:" Style="{StaticResource BlockLabel}" Width="130"/>
                        <PasswordBox x:Name="OldPasswordBox" Grid.Column="1" Style="{StaticResource NeonPasswordBox}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Новый пароль:" Style="{StaticResource BlockLabel}" Width="130"/>
                        <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" Style="{StaticResource NeonPasswordBox}"/>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Желаемый пароль:" Style="{StaticResource BlockLabel}" Width="130"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Column="1" Style="{StaticResource NeonPasswordBox}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сменить пароль" Width="130" Style="{StaticResource GreenButton}" Margin="0,0,10,0" Click="SubmitPassword_Click"/>
                        <Button Content="Отмена" Width="100"
                                Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12" Click="CancelPassword_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="NotificationOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="380" MaxWidth="420">
                <StackPanel>
                    <TextBlock x:Name="NotifTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessColor}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NotifText" Text="" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,20" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Button Content="OK" Width="100"
                            Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource SuccessColor}"
                            BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1" Padding="10,6"
                            Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                            HorizontalAlignment="Center" x:Name="NotifOkBtn" Click="NotifOkButton_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="ConfirmOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource GreenButtonForeground}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420" MaxWidth="500">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource GreenButtonForeground}" Margin="0,0,0,8"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ConfirmText" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Да" Width="100"
                                Background="{DynamicResource GreenButtonBackground}" Foreground="{DynamicResource GreenButtonForeground}"
                                BorderBrush="{DynamicResource GreenButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                                x:Name="ConfirmYesBtn" Margin="0,0,10,0"/>
                        <Button Content="Нет" Width="100"
                                Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12"
                                x:Name="ConfirmNoBtn"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>