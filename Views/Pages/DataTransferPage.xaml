<UserControl x:Class="BlankFiller.Views.Pages.DataTransferPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="BlockLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" x:Name="border">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsEditable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" x:Name="MainBorder">
                            <Grid>
                                <TextBlock x:Name="ContentSite" VerticalAlignment="Center" Margin="8,0,20,0"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding SelectionBoxItem}"/>
                                <ToggleButton x:Name="ToggleButton"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press" Focusable="False"
                                              HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                              Width="20" Background="Transparent" BorderThickness="0">
                                    <Path Data="M 0 0 L 3 3 L 6 0 Z" Fill="{DynamicResource AccentColor}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </ToggleButton>
                                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" StaysOpen="False">
                                    <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource AccentColor}" BorderThickness="1"
                                            CornerRadius="6" Margin="0,2" MinWidth="{TemplateBinding ActualWidth}">
                                        <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GreenButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource GreenButtonForeground}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GreenButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GreenButtonHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GreenButtonForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="YellowCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Width="20" Height="20"
                                    Background="{DynamicResource InputBackground}" BorderBrush="#FFD700" BorderThickness="1.5"
                                    CornerRadius="4" Margin="0,0,10,0">
                                <Path x:Name="checkMark" Data="M 2 9 L 7 14 L 17 4"
                                      Stroke="#FFD700" StrokeThickness="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#FFE44D"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="#FFE44D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#92D050"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Width="20" Height="20"
                                    Background="{DynamicResource InputBackground}" BorderBrush="#92D050" BorderThickness="1.5"
                                    CornerRadius="4" Margin="0,0,10,0">
                                <Path x:Name="checkMark" Data="M 2 9 L 7 14 L 17 4"
                                      Stroke="#92D050" StrokeThickness="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#A8E060"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="#A8E060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Width="20" Height="20"
                                    Background="{DynamicResource InputBackground}" BorderBrush="#FF8B5A6A" BorderThickness="1.5"
                                    CornerRadius="4" Margin="0,0,10,0">
                                <Path x:Name="checkMark" Data="M 2 9 L 7 14 L 17 4"
                                      Stroke="#FF8B5A6A" StrokeThickness="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource RegistryAccent}"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="{DynamicResource RegistryAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="80,20,80,20">
                <StackPanel>

                    <TextBlock Text="Перенос данных в таблицы"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- ========== ТАБЛИЦА ДОЛЖНИКОВ ========== -->
                    <Border Background="{DynamicResource PanelBackground}" CornerRadius="12"
                            BorderBrush="#FF7E57C2" BorderThickness="1" Padding="20,14" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Информация для проверки" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                <Border Background="#FF7E57C2" CornerRadius="10" Padding="12,4" HorizontalAlignment="Right">
                                    <TextBlock Text="Таблица должников" FontSize="12" FontWeight="SemiBold" Foreground="#E0E0FF"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ф.И.О.:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtNameBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                                <TextBlock Text="Дата рождения:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtBirthBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Место жительства:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtResidenceBox" Grid.Column="1" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Доставлен:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtDeliveryDateBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                                <TextBlock Text="Выписка:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtReleaseDateBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Статья:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBox x:Name="DebtArticlePartBox" Style="{StaticResource InputBox}" Width="55"/>
                                    <TextBox x:Name="DebtArticleBox" Style="{StaticResource InputBox}" Width="65" Margin="4,0,0,0"/>
                                    <TextBlock Text="Номер акта:" Style="{StaticResource BlockLabel}" Width="80" Margin="8,0,4,0"/>
                                    <TextBox x:Name="DebtActNumberBox" Style="{StaticResource InputBox}" Width="70"/>
                                </StackPanel>
                                <TextBlock Text="Кем доставлен:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="DebtDeliveredByBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Button Content="Перенести данные" Style="{StaticResource GreenButton}"
                                    HorizontalAlignment="Center" Margin="0,6,0,0" Click="TransferDebt_Click"/>
                            <Button Content="📊 Просмотр таблицы" Style="{StaticResource GreenButton}"
                                    HorizontalAlignment="Center" Margin="0,6,0,0" Click="ViewDebtTable_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- ========== ОПЛАТА ========== -->
                    <Border Background="{DynamicResource PanelBackground}" CornerRadius="12"
                            BorderBrush="#FF8B5A6A" BorderThickness="1" Padding="20,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Оплата" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FF8B5A6A" Margin="0,0,0,10"/>
                            <CheckBox x:Name="PaymentCheckBox" Content="Производилась оплата?"
                                      Style="{StaticResource NeonCheckBox}" Margin="0,0,0,10"
                                      Checked="PaymentCheckBox_Changed" Unchecked="PaymentCheckBox_Changed"/>
                            <Grid x:Name="PaymentGrid" IsEnabled="False" Opacity="0.5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PaymentSumBox" Grid.Column="0" Style="{StaticResource InputBox}"
                                         Text="Сумма" Foreground="{DynamicResource PlaceholderColor}" Margin="0,0,6,0"
                                         GotFocus="Placeholder_GotFocus" LostFocus="Placeholder_LostFocus" Tag="Сумма"/>
                                <TextBox x:Name="PaymentTimeBox" Grid.Column="1" Style="{StaticResource InputBox}"
                                         Text="при выписке" Margin="0,0,6,0"/>
                                <ComboBox x:Name="PaymentMethodCombo" Grid.Column="2" Style="{StaticResource NeonComboBox}" SelectedIndex="0">
                                    <ComboBoxItem Content="нал"/><ComboBoxItem Content="безнал"/>
                                </ComboBox>
                            </Grid>
                            <StackPanel x:Name="PaymentTypePanel" Orientation="Horizontal" Margin="0,8,0,0" IsEnabled="False" Opacity="0.5">
                                <CheckBox x:Name="FullPaymentCheckBox" Content="Полная оплата" Style="{StaticResource YellowCheckBox}" Margin="0,0,20,0"/>
                                <CheckBox x:Name="PartialPaymentCheckBox" Content="Частичная оплата" Style="{StaticResource GreenCheckBox}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Сохранить данные для реестра" Style="{StaticResource GreenButton}" Margin="0,0,10,0" Click="SaveForRegistry_Click"/>
                                <Button Content="Перейти в реестр" Style="{StaticResource GreenButton}" Click="GoToRegistry_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ========== ТАБЛИЦА НЕРАБОТАЮЩИХ ========== -->
                    <Border Background="{DynamicResource PanelBackground}" CornerRadius="12"
                            BorderBrush="#FF26C6DA" BorderThickness="1" Padding="20,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Информация для проверки" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                <Border Background="#FF26C6DA" CornerRadius="10" Padding="12,4" HorizontalAlignment="Right">
                                    <TextBlock Text="Таблица неработающих" FontSize="12" FontWeight="SemiBold" Foreground="#0A0A1A"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ф.И.О.:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="UnempNameBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                                <TextBlock Text="Дата рождения:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="UnempBirthBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Место жительства:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="UnempResidenceBox" Grid.Column="1" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Дата вручения:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="UnempDeliveryDateBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                                <TextBlock Text="Сокращение:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="130"/>
                                <TextBox x:Name="UnempShortNameBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Статья:" Style="{StaticResource BlockLabel}" Width="130"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBox x:Name="UnempArticlePartBox" Style="{StaticResource InputBox}" Width="60"/>
                                    <TextBox x:Name="UnempArticleBox" Style="{StaticResource InputBox}" Width="70" Margin="4,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="Идент. номер:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="120"/>
                                <TextBox x:Name="UnempIdBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                            </Grid>

                            <Button Content="Перенести данные" Style="{StaticResource GreenButton}"
                                    HorizontalAlignment="Center" Margin="0,6,0,0" Click="TransferUnemp_Click"/>
                            <Button Content="📊 Просмотр таблицы" Style="{StaticResource GreenButton}"
                                    HorizontalAlignment="Center" Margin="0,6,0,0" Click="ViewUnempTable_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Диалог подтверждения переноса -->
        <Border x:Name="ConfirmOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource GreenButtonForeground}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420" MaxWidth="500">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource GreenButtonForeground}" Margin="0,0,0,8"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ConfirmText" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Да" Width="100"
                                Background="{DynamicResource GreenButtonBackground}" Foreground="{DynamicResource GreenButtonForeground}"
                                BorderBrush="{DynamicResource GreenButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                                x:Name="ConfirmYesBtn" Margin="0,0,10,0"/>
                        <Button Content="Нет" Width="100"
                                Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12"
                                x:Name="ConfirmNoBtn"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>