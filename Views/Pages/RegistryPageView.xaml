<UserControl x:Class="BlankFiller.Views.Pages.RegistryPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="BlockLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" x:Name="border">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ReadOnlyBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource ReadOnlyBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ReadOnlyForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>
        <Style x:Key="NeonCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Width="18" Height="18" Background="{DynamicResource InputBackground}"
                                    BorderBrush="{DynamicResource RegistryBorder}" BorderThickness="1.5" CornerRadius="3" Margin="0,0,8,0">
                                <Path x:Name="checkMark" Data="M 2 8 L 6 12 L 15 3" Stroke="{DynamicResource RegistryBorder}"
                                      StrokeThickness="2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource RegistryAccent}"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="{DynamicResource RegistryAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GreenButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource GreenButtonForeground}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GreenButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GreenButtonHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource GreenButtonForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DeleteButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ErrorColor}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeleteButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DeleteButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="RedRoundedTextBoxTemplate" TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" x:Name="border">
                <ScrollViewer x:Name="PART_ContentHost" Margin="2,1"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#FF6B5A5A"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="80,20,80,20">
                <TextBlock Text="Реестр" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <Border Background="{DynamicResource PanelBackground}" CornerRadius="12" BorderBrush="{DynamicResource RegistryBorder}"
                        BorderThickness="1" Padding="20,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Реестр" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource RegistryBorder}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Номер квитанции:" Style="{StaticResource BlockLabel}" Width="120"/>
                            <TextBox x:Name="ReceiptNumberBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                            <TextBlock Text="Номер акта:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="80"/>
                            <TextBox x:Name="ActNumberBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Дата составления:" Style="{StaticResource BlockLabel}" Width="120"/>
                            <TextBox x:Name="ComposeDateBox" Grid.Column="1" Style="{StaticResource InputBox}" Margin="0,0,10,0"/>
                            <TextBlock Text="Сумма:" Grid.Column="2" Style="{StaticResource BlockLabel}" Width="50"/>
                            <TextBox x:Name="SumBox" Grid.Column="3" Style="{StaticResource InputBox}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <CheckBox x:Name="CashCheckBox" Content="Наличный" Style="{StaticResource NeonCheckBox}" Margin="0,0,20,0"/>
                            <CheckBox x:Name="NonCashCheckBox" Content="Безналичный" Style="{StaticResource NeonCheckBox}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <Button Content="✓ Внести данные в реестр" Style="{StaticResource GreenButton}" Margin="0,0,10,0" Click="SubmitManualEntry_Click"/>
                            <Button Content="📄 Посмотреть Реестр" Style="{StaticResource GreenButton}" Click="ViewRegistry_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Сохранённые данные" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentColor}" Margin="0,0,0,10"/>
                <WrapPanel x:Name="SavedEntriesPanel"/>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="FileChoiceOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource AccentColor}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420" MaxWidth="500">
                <StackPanel>
                    <TextBlock Text="В какой файл вы хотите внести данные?" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,0,16" TextAlignment="Center"/>
                    <StackPanel x:Name="FileChoicePanel"/>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="NotificationOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="380" MaxWidth="420">
                <StackPanel>
                    <TextBlock x:Name="NotifTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessColor}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NotifText" Text="" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,20" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Button Content="OK" Width="100"
                            Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource SuccessColor}"
                            BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1" Padding="10,6"
                            Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                            HorizontalAlignment="Center" Click="HideNotification_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="ConfirmOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource GreenButtonForeground}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="420" MaxWidth="500">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource GreenButtonForeground}" Margin="0,0,0,8"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ConfirmText" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Да" Width="100"
                                Background="{DynamicResource GreenButtonBackground}" Foreground="{DynamicResource GreenButtonForeground}"
                                BorderBrush="{DynamicResource GreenButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12" FontWeight="SemiBold"
                                x:Name="ConfirmYesBtn" Margin="0,0,10,0"/>
                        <Button Content="Нет" Width="100"
                                Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                Padding="10,6" Cursor="Hand" FontSize="12"
                                x:Name="ConfirmNoBtn"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>