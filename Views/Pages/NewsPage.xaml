<UserControl x:Class="BlankFiller.Views.Pages.NewsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="80,30,80,30">
                <TextBlock Text="Новости" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <StackPanel x:Name="NewsListPanel"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Модальное окно новости -->
        <Border x:Name="NewsModalOverlay" Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource DialogBackground}" BorderBrush="{DynamicResource NewsAccent}" BorderThickness="1"
                    CornerRadius="16" Padding="30,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="1000" Height="700" MaxWidth="1200" MaxHeight="800">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel x:Name="ModalHeader"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel x:Name="ModalItemsPanel"/>
                    </ScrollViewer>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="{DynamicResource TextTertiary}" BorderThickness="0"
                            FontSize="18" Cursor="Hand" Margin="0,-15,-10,0"
                            Click="CloseModal_Click"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>